# Server Configuration
PORT=3001
NODE_ENV=development

# Database - Production Supabase instance required (simulation mode disabled)
SUPABASE_URL=https://demo.supabase.co
SUPABASE_ANON_KEY=demo-key
SUPABASE_SERVICE_ROLE_KEY=demo-service-key

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
BCRYPT_ROUNDS=12

# AI Services (add your real keys here)
GOOGLE_AI_API_KEY=your_google_ai_api_key
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key
OLLAMA_BASE_URL=http://localhost:11434

# Security Tools (simulation mode disabled - real connections required)
BURP_API_URL=http://localhost:8080
BURP_API_KEY=demo-burp-key
ZAP_API_URL=http://localhost:8090
ZAP_API_KEY=demo-zap-key

# CORS
FRONTEND_URL=http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FILE=logs/server.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads/